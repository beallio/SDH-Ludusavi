{
  "name": "sdh-ludusavi",
  "version": "0.3.0",
  "description": "Decky Loader panel for Ludusavi save backup and restore controls",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level moderate",
    "test:unit": "vitest run",
    "test": "pnpm run test:unit && pnpm run typecheck",
    "verify": "bash scripts/check_frontend_supply_chain.sh",
    "watch": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beallio/SDH-Ludusavi.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "ludusavi",
    "save-backup",
    "steam-deck",
    "deck"
  ],
  "author": "David Beall <6121439+beallio@users.noreply.github.com>",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/beallio/SDH-Ludusavi/issues"
  },
  "homepage": "https://github.com/beallio/SDH-Ludusavi#readme",
  "dependencies": {
    "@decky/api": "1.1.3",
    "react-icons": "5.3.0",
    "react-router": "6.30.4",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@decky/rollup": "1.0.2",
    "@decky/ui": "4.11.0",
    "@rollup/rollup-linux-x64-musl": "4.59.1",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "4.59.1",
    "typescript": "5.6.2",
    "vitest": "4.1.8"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.1.7": "1.1.13",
      "brace-expansion@^2.0.0": "2.0.3",
      "minimatch@^3.0.0": "3.1.5",
      "minimatch@^9.0.0": "9.0.9",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
