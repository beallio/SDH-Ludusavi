#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"

root="$(repo_root)"
cd "$root"

if [[ -n "$slug" ]]; then
  require_slug "$slug"

  if plan="$(latest_plan_file "$slug")"; then
    printf '%s\n' "$plan"
    exit 0
  fi

  die "no plan found for slug: $slug"
fi

shopt -s nullglob
plans=(docs/plans/*.md)
shopt -u nullglob

if (( ${#plans[@]} == 0 )); then
  die "no plans found under docs/plans"
fi

# Return most recently modified plan. This supports read-only planning flows where
# the orchestrator writes the plan before starting the implementer.
ls -t docs/plans/*.md | head -n 1
