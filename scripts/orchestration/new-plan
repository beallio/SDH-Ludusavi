#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"
title="${2:-}"

require_slug "$slug"

root="$(repo_root)"
cd "$root"

ensure_dirs

date_prefix="${PLAN_DATE:-$(date +%F)}"
plan_path="docs/plans/${date_prefix}_${slug}.md"
branch="feat/${slug}"
finished="$(finished_marker "$slug")"
finalized="$(finalized_marker "$slug")"

[[ -n "$title" ]] || title="$slug"
[[ ! -e "$plan_path" ]] || die "plan already exists: $plan_path"

cat > "$plan_path" <<EOF
# Plan: ${title} (${slug})

## Context

TODO: Describe the user-visible problem, intended outcome, and relevant files.

**Slug used throughout this plan:** \`${slug}\`

---

## Orchestration Contract

**Slug:** \`${slug}\`

**Plan file:**

\`\`\`text
${plan_path}
\`\`\`

**Implementation branch:**

\`\`\`text
${branch}
\`\`\`

**Round-complete marker:**

\`\`\`text
${finished}
\`\`\`

**Finalized marker:**

\`\`\`text
${finalized}
\`\`\`

**Review notes:**

\`\`\`text
docs/review/${slug}-review-*.md
\`\`\`

Each review note ends with exactly one status trailer:

\`\`\`text
STATUS: CHANGES_REQUESTED
\`\`\`

or:

\`\`\`text
STATUS: APPROVED
\`\`\`

---

## Required Agent Protocol

1. Use the **implementer** skill.
2. Work from the repository root.
3. Branch from \`dev\`.
4. Commit this plan as the first commit on the implementation branch.
5. Follow TDD where behavior changes are testable.
6. Run quality gates before marking any round complete.
7. Do not write your own review.
8. Do not create files under \`docs/review/\`.
9. Do not delete files under \`docs/review/\`.
10. Review notes are durable audit records and must be committed.
11. Resolving a review note means:
    - implement the requested changes;
    - run quality gates;
    - commit the code/docs changes;
    - commit the review note itself if it is not already committed;
    - recreate the round-complete marker.
12. After finalization, stop polling and exit cleanly.

---

## Setup

Start from \`dev\`:

\`\`\`bash
git checkout dev
git pull --ff-only origin dev
git checkout -b ${branch}
\`\`\`

Commit this plan first:

\`\`\`bash
git add ${plan_path}
git commit -m "docs(plan): add ${slug} implementation plan"
\`\`\`

---

## Implementation Tasks

TODO: Write direct implementer instructions. Be explicit enough for a low-context agent.

---

## Quality Gates

Run before marking any round complete:

\`\`\`bash
scripts/orchestration/run-quality-gates
scripts/orchestration/check-review-notes-not-deleted
git status --short
\`\`\`

The round is not complete unless:

1. all requested implementation work is done;
2. all relevant tests pass;
3. build/typecheck gates pass;
4. review notes have not been deleted;
5. the working tree is clean;
6. all code/docs changes are committed.

---

## Verification

TODO: List manual verification steps.

TODO: Explicitly state any deferred verification, such as on-device Steam Deck testing.

---

## Mark Round Complete

When the implementation round is complete and the working tree is clean, run:

\`\`\`bash
scripts/orchestration/mark-finished ${slug}
\`\`\`

This writes:

\`\`\`text
${finished}
\`\`\`

Then continue polling for review notes.

---

## Review Polling Loop

After marking the round complete, poll for review notes:

\`\`\`text
docs/review/${slug}-review-*.md
\`\`\`

When a new review note appears:

1. Read the full review note.
2. If the note ends with:

   \`\`\`text
   STATUS: CHANGES_REQUESTED
   \`\`\`

   then resume work.

3. Clear the round-complete marker:

   \`\`\`bash
   scripts/orchestration/clear-finished ${slug}
   \`\`\`

4. Address every requested change.
5. Run quality gates:

   \`\`\`bash
   scripts/orchestration/run-quality-gates
   scripts/orchestration/check-review-notes-not-deleted
   \`\`\`

6. Commit code/docs fixes.
7. Commit the review-note file itself if it is not already committed:

   \`\`\`bash
   git add docs/review/${slug}-review-*.md
   git commit -m "docs(review): record ${slug} review notes"
   \`\`\`

8. Recreate the round-complete marker:

   \`\`\`bash
   scripts/orchestration/mark-finished ${slug}
   \`\`\`

9. Continue polling.

---

## Approval Handling

If the latest review note ends with:

\`\`\`text
STATUS: APPROVED
\`\`\`

then:

1. Confirm every previous review item has been addressed.
2. Confirm all review notes are committed:

   \`\`\`bash
   scripts/orchestration/check-review-notes-committed ${slug}
   \`\`\`

3. Confirm the working tree is clean:

   \`\`\`bash
   git status --short
   \`\`\`

4. Finalize:

   \`\`\`bash
   scripts/orchestration/finalize ${slug}
   \`\`\`

5. Confirm the finalized marker exists:

   \`\`\`text
   ${finalized}
   \`\`\`

6. Stop polling and exit cleanly.

---

## Review Rules

Do not write your own review.

Do not create files under:

\`\`\`text
docs/review/
\`\`\`

Do not delete files under:

\`\`\`text
docs/review/
\`\`\`

Only the orchestrator writes review notes. Your job is to read them, resolve them, commit them as audit records, and continue the loop.

---

## Finalization Rules

Only finalize after a review note with:

\`\`\`text
STATUS: APPROVED
\`\`\`

Finalization is performed with:

\`\`\`bash
scripts/orchestration/finalize ${slug}
\`\`\`

Do not manually merge into \`dev\` unless the finalize script fails and the user/orchestrator explicitly instructs you to recover manually.

Leave both markers in place after finalization:

\`\`\`text
${finished}
${finalized}
\`\`\`

Steam Deck/user testing is deferred until after \`dev\` is pushed to GitHub and the dev release is requested.
EOF

echo "Created plan: $plan_path"
echo "Slug: $slug"
echo "Branch: $branch"
echo "Round-complete marker: $finished"
echo "Finalized marker: $finalized"
echo "Review notes: docs/review/${slug}-review-*.md"
