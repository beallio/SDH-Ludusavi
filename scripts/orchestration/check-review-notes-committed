#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"

require_slug "$slug"

root="$(repo_root)"
cd "$root"

shopt -s nullglob
files=(docs/review/"${slug}"-review-*.md)
shopt -u nullglob

if (( ${#files[@]} == 0 )); then
  die "no review notes found for slug: $slug"
fi

dirty="$(git status --porcelain -- "${files[@]}")"

if [[ -n "$dirty" ]]; then
  echo "review notes are not fully committed/clean:" >&2
  echo "$dirty" >&2
  exit 1
fi

for f in "${files[@]}"; do
  git ls-files --error-unmatch "$f" >/dev/null 2>&1 \
    || die "review note is not tracked: $f"
done

echo "all review notes for $slug are committed"
