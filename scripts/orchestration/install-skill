#!/usr/bin/env bash
set -euo pipefail

# Install the repo-local orchestrated-implementation skill into the active agent skill directory.
#
# Defaults to Claude-style skill path:
#   ~/.claude/skills/orchestrated-implementation/SKILL.md
#
# Override with:
#   AGENT_SKILLS_DIR=/path/to/skills scripts/orchestration/install-skill

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "error: not inside a git repository" >&2
  exit 1
}

SRC="$ROOT/docs/agent-skills/orchestrated-implementation/SKILL.md"
AGENT_SKILLS_DIR="${AGENT_SKILLS_DIR:-$HOME/.claude/skills}"
DEST_DIR="$AGENT_SKILLS_DIR/orchestrated-implementation"
DEST="$DEST_DIR/SKILL.md"

if [[ ! -f "$SRC" ]]; then
  echo "error: source skill not found: $SRC" >&2
  exit 1
fi

mkdir -p "$DEST_DIR"
cp "$SRC" "$DEST"

echo "installed skill:"
echo "  $DEST"
