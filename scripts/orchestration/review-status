#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"

require_slug "$slug"

root="$(repo_root)"
cd "$root"

shopt -s nullglob
files=(docs/review/"${slug}"-review-*.md)
shopt -u nullglob

# Only committed review notes count. The durable trigger is the committed note,
# so read each note's content from HEAD (git show HEAD:<path>). A note that is
# present in the working tree but not yet committed at HEAD is ignored, which
# avoids acting on a half-written or uncommitted note.
committed=()
for f in "${files[@]}"; do
  if git show "HEAD:$f" >/dev/null 2>&1; then
    committed+=("$f")
  fi
done

if (( ${#committed[@]} == 0 )); then
  echo "NO_REVIEW"
  exit 0
fi

for f in "${committed[@]}"; do
  count="$(git show "HEAD:$f" | grep -E '^STATUS: (CHANGES_REQUESTED|APPROVED)$' | wc -l | tr -d ' ')"

  if [[ "$count" != "1" ]]; then
    echo "INVALID"
    echo "invalid or missing STATUS trailer in committed note: $f" >&2
    exit 2
  fi
done

latest="$(printf '%s\n' "${committed[@]}" | sort | tail -n 1)"
status="$(git show "HEAD:$latest" | grep -E '^STATUS: (CHANGES_REQUESTED|APPROVED)$' | sed 's/^STATUS: //')"

echo "$status"
