#!/usr/bin/env bash
set -euo pipefail

plan_path="${1:-}"

if [[ -z "$plan_path" ]]; then
  echo "usage: $0 <plan-path>" >&2
  exit 1
fi

base="$(basename "$plan_path")"
base="${base%.md}"

# Strip common date prefix: YYYY-MM-DD_
base="$(printf '%s\n' "$base" | sed -E 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}_//')"

if [[ -z "$base" ]]; then
  echo "error: could not infer slug from plan path: $plan_path" >&2
  exit 1
fi

printf '%s\n' "$base"
