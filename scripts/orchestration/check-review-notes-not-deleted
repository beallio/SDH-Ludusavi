#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

root="$(repo_root)"
cd "$root"

deleted="$(
  git status --porcelain -- docs/review \
    | awk 'substr($0,1,2) ~ /D/ { print }'
)"

if [[ -n "$deleted" ]]; then
  echo "Review notes must not be deleted. Commit them as audit trail." >&2
  echo "$deleted" >&2
  exit 1
fi

echo "no deleted review notes"
