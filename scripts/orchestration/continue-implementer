#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

requested_slug="${1:-}"

root="$(repo_root)"
cd "$root"

ensure_dirs

command -v agy >/dev/null 2>&1 || die "agy not found on PATH"

if [[ -n "$requested_slug" ]]; then
  require_slug "$requested_slug"
  plan_path="$(scripts/orchestration/latest-plan "$requested_slug")"
  slug="$requested_slug"
else
  plan_path="$(scripts/orchestration/latest-plan)"
  slug="$(scripts/orchestration/infer-slug-from-plan "$plan_path")"
  require_slug "$slug"
fi

session_name="$(tmux_session_name "$slug")"

prompt="$(cat <<EOF
Continue the existing implementation workflow for plan ${plan_path}.

You are being resumed by the orchestrator with agy -c after a review note or approval note has already been written and committed, or after an implementation round requires continuation.

Do not wait for a future docs/plans create event. The plan already exists.

Start by reading:
${plan_path}

Then immediately scan the current review notes:
docs/review/${slug}-review-*.md

Important:
- First process review notes that already exist.
- Do not block on inotifywait before checking existing review files.
- The orchestrator always writes and commits the review note before resuming you.
- Read the latest review note's committed content (for example via git show HEAD:docs/review/${slug}-review-*.md), not the working-tree file, so a half-written or uncommitted note is never acted upon.
- Treat the latest committed review note as the source of truth.

If the latest applicable review note ends with STATUS: CHANGES_REQUESTED:
1. Clear the round-complete marker using the command specified in the plan.
2. Implement every requested change.
3. Run the plan's quality gates.
4. Commit code/docs fixes.
5. Commit the review-note file itself if it has not already been committed.
6. Recreate the round-complete marker.
7. Exit cleanly. Do not poll for further review notes in-session; the orchestrator will resume you again once the next review note is committed.

If the latest applicable review note ends with STATUS: APPROVED:
1. Confirm review notes are committed.
2. Confirm the working tree is clean.
3. Finalize using the finalize command specified in the plan.
4. Confirm the finalized marker exists.
5. Exit cleanly.

If no applicable review note exists yet, exit cleanly without polling; the orchestrator will resume you once the next review note is committed.
EOF
)"

run_foreground() {
  exec agy \
    --add-dir /tmp \
    --print-timeout "${AGY_PRINT_TIMEOUT:-60m}" \
    -c \
    -p "$prompt"
}

if [[ "${ORCH_FOREGROUND:-0}" == "1" ]]; then
  run_foreground
fi

command -v tmux >/dev/null 2>&1 || {
  echo "tmux not found; falling back to foreground continue mode." >&2
  echo "Install tmux or rerun with ORCH_FOREGROUND=1 to make this explicit." >&2
  run_foreground
}

if tmux has-session -t "$session_name" 2>/dev/null; then
  echo "implementer session already running: $session_name"
  echo "plan: $plan_path"
  exit 0
fi

prompt_file="$(mktemp "$(tmp_root)/${slug}_agy_continue_prompt.XXXXXX")"
printf '%s\n' "$prompt" > "$prompt_file"

tmux new-session -d \
  -s "$session_name" \
  -c "$root" \
  "AGY_PRINT_TIMEOUT='${AGY_PRINT_TIMEOUT:-60m}' bash -lc 'exec agy --add-dir /tmp --print-timeout \"\$AGY_PRINT_TIMEOUT\" -c -p \"\$(cat \"$prompt_file\")\"'"

echo "continued implementer in tmux session: $session_name"
echo "repo: $root"
echo "plan: $plan_path"
echo "prompt file: $prompt_file"
