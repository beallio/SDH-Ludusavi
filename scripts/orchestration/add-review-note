#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"
status="${2:-CHANGES_REQUESTED}"

require_slug "$slug"

case "$status" in
  CHANGES_REQUESTED|APPROVED)
    ;;
  changes|changes_requested|CHANGES|requested)
    status="CHANGES_REQUESTED"
    ;;
  approved|pass|passed|APPROVE)
    status="APPROVED"
    ;;
  *)
    die "invalid status: $status; use CHANGES_REQUESTED or APPROVED"
    ;;
esac

root="$(repo_root)"
cd "$root"

ensure_dirs

shopt -s nullglob
existing=(docs/review/"${slug}"-review-*.md)
shopt -u nullglob

next=1

if (( ${#existing[@]} > 0 )); then
  last="$(
    printf '%s\n' "${existing[@]}" \
      | sed -E "s#.*${slug}-review-([0-9]+)\.md#\1#" \
      | sort -n \
      | tail -n 1
  )"

  next=$((10#$last + 1))
fi

round="$(printf '%02d' "$next")"
note_path="docs/review/${slug}-review-${round}.md"
branch="$(current_branch)"

plan="$(latest_plan_file "$slug" || true)"
[[ -n "${plan:-}" ]] || plan="TODO: plan path"

cat > "$note_path" <<EOF
# Review — ${slug} (round ${round})

Branch: \`${branch}\`
Reviewed against: \`${plan}\`

## Verdict

TODO

## Gate status

TODO

## Required changes

TODO

STATUS: ${status}
EOF

echo "created review note: $note_path"
