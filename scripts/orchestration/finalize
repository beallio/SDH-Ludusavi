#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"
version="${2:-}"

require_slug "$slug"

root="$(repo_root)"
cd "$root"

status="$(scripts/orchestration/review-status "$slug")"
[[ "$status" == "APPROVED" ]] || die "latest review status is not APPROVED: $status"

scripts/orchestration/check-review-notes-not-deleted
scripts/orchestration/check-review-notes-committed "$slug"

require_clean_worktree

feature_branch="${FEATURE_BRANCH:-feat/${slug}}"
current="$(current_branch)"

[[ "$current" == "$feature_branch" ]] || die "expected current branch $feature_branch, got $current"

if [[ -z "$version" ]]; then
  if command -v node >/dev/null 2>&1 && [[ -f package.json ]]; then
    version="$(node -p "require('./package.json').version")"
  else
    die "release version not supplied and package.json/node unavailable"
  fi
fi

[[ -x ./scripts/request_dev_release.sh ]] || die "missing executable ./scripts/request_dev_release.sh"

if command -v gh >/dev/null 2>&1; then
  gh auth status >/dev/null 2>&1 || die "gh auth missing; run gh auth login"
else
  die "gh not found on PATH"
fi

git fetch origin
git checkout dev
git pull --ff-only origin dev
git merge --no-ff --no-edit "$feature_branch"
git push origin dev
git branch -d "$feature_branch"

if [[ "${ORCH_DELETE_REMOTE_BRANCH:-0}" == "1" ]]; then
  git push origin --delete "$feature_branch" || true
fi

./scripts/request_dev_release.sh "$version"

finished="$(finished_marker "$slug")"
finalized="$(finalized_marker "$slug")"

: > "$finished"
: > "$finalized"

echo "finalized $slug"
echo "dev pushed"
echo "dev release requested for version $version"
echo "round-complete marker left in place: $finished"
echo "finalized marker written: $finalized"
