#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

slug="${1:-}"

require_slug "$slug"

root="$(repo_root)"
cd "$root"

ensure_dirs
require_clean_worktree

marker="$(finished_marker "$slug")"
# Stamp the marker with the current HEAD sha so the orchestrator can tell a
# fresh round-complete from a stale one (see wait-for-finished ORCH_FINISHED_SINCE).
head_sha="$(git rev-parse HEAD)"
printf '%s\n' "$head_sha" > "$marker"

echo "wrote round-complete marker: $marker ($head_sha)"
